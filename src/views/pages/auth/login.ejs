<!DOCTYPE html>
<html lang="vi">

<head>
	<meta charset="UTF-8">
	<meta name="theme-color" content="#2a7ee4">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta name="author" content="IE104.O12_Nhom2">
	<meta name="description" content="Hãy đăng nhập để trở thành thành viên của gia đình TECHMO nhé.">

	<link rel="shortcut icon" type="image/x-icon" href="/imgs/ico-logo-blue.png">
	<link rel="stylesheet" href="/styles/pages/auth/login.css">

	<title>TECHMO. Đăng nhập</title>
</head>

<body>
	<%- include('../../partials/header-small', title='Đăng nhập')%>

	<main class="login_main">
		<div class="login__box">
			<div class="login__inner-box">
				<div class="login__forms-wrap">
					<form id="form" autocomplete="off" class="login__sign-in-form">
						<div class="login__logo">
							<a href="#"><img src="/imgs/logo-blue.png" alt="TECHMO"> </a>
						</div>

						<div class="login__heading">
							<h1>Chào mừng quay trở lại TECHMO.</h1>
							<h4>
								Chưa có tài khoản?
								<a href="/auth/register" class="login__toggle">
									Đăng ký ngay</a>
							</h4>
						</div>

						<div class="actual-form">
							<div class="login__input-wrap">
								<input id="phoneNumber" type="text" name="phoneNumber" class="login__input-field" autocomplete="off">
								<label>Số điện thoại<span class="red-start">*</span></label>
								<div class="login__error"></div>
							</div>

							<div class="login__input-wrap">
								<input id="password" type="password" name="password" class="login__input-field" autocomplete="off">
								<label>Mật khẩu<span class="red-start">*</span></label>
								<span id="togglePassword" class="login__toggle-password"><span class="material-symbols-outlined eye-open">
										visibility</span>
								</span>
								<div class="login__error"></div>
							</div>
							<div class="login__input-wrap" style="display: flex; gap: 10px; align-items: flex-end; height: auto; margin-bottom: 2rem;">
								<div style="flex: 1; position: relative; height: 37px;">
									<input type="text" id="captcha" name="captcha" class="login__input-field" autocomplete="off">
									<label>Mã xác nhận<span class="red-start">*</span></label>
									<div class="login__error"></div>
								</div>
								<div class="captcha-container" style="height: 37px; display: flex; align-items: center; gap: 5px;">
									<img src="/auth/captcha" id="captcha-img" alt="Captcha" style="height: 100%; border-radius: 4px; cursor: pointer;" title="Click để đổi mã">
									<button type="button" id="refresh-captcha" style="background: none; border: none; cursor: pointer; color: var(--primary-color-1); display: flex; align-items: center;">
										<span class="material-symbols-outlined" style="font-size: 20px;">refresh</span>
									</button>
								</div>
							</div>

							<input type="submit" value="Đăng nhập" class="login__sign-btn">
							<p class="login__text">
								<a href="/auth/forgot">Quên mật khẩu?</a>
							</p>
						</div>
					</form>
				</div>

				<div class="login__carousel">
					<div class="login__images-wrapper">
						<img src="/imgs/slider/image1.png" class="login__image login__img-1 show" alt="">
						<img src="/imgs/slider/image2.png" class="login__image login__img-2" alt="">
						<img src="/imgs/slider/image3.png" class="login__image login__img-3" alt="">
					</div>
				</div>
			</div>
		</div>
	</main>

	<%- include('../../components/scrollup') %>
	<%- include('../../partials/footer') %>
	<%- include('../../partials/app-bar') %>

	<script src="/scripts/pages/auth/login.js"></script>

</body>

</html>