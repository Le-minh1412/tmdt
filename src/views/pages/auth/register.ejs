<!DOCTYPE html>
<html lang="vi">

<head>
	<meta charset="UTF-8">
	<meta name="theme-color" content="#2a7ee4">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<meta name="author" content="IE104.O12_Nhom2">
	<meta name="description" content="Hãy đăng ký để trở thành một phần của TECHMO và hãy để TECHMO trở thành một phần của bạn.">

	<link rel="shortcut icon" type="image/x-icon" href="/imgs/ico-logo-blue.png">
	<link rel="stylesheet" href="/styles/pages/auth/register.css">

	<title>TECHMO. Đăng ký</title>
</head>

<body>
	<%- include('../../partials/header-small', title='Đăng ký') %>

	<main class="register_main">
		<div class="register__box">
			<div class="register__inner-box">
				<div class="register__forms-wrap">
					<form id="form" autocomplete="off" class="register__sign-in-form">
						<div class="register__logo">
							<!-- Về trang chủ -->
							<a href="#"><img src="/imgs/logo-blue.png" alt="TECHMO"></a>
							<div class="register__heading">
								<h1>Chào mừng đến với TECHMO.</h1>
								<h4>
									Đã có tài khoản?
									<a href="/auth/login" class="register__toggle">Đăng nhập ngay</a>
								</h4>
							</div>
						</div>

						<div class="register__actual-form">
							<div class="register__input-wrap">
								<input type="text" id="userName" name="userName" class="register__input-field" autocomplete="off">
								<label>Họ tên<span class="red-start">*</span></label>
								<div class="register__error"></div>
							</div>

							<div class="register__input-wrap">
								<input type="text" id="phoneNumber" name="phoneNumber" class="register__input-field" autocomplete="off">
								<label>Số điện thoại<span class="red-start">*</span></label>
								<div class="register__error"></div>
							</div>

							<div class="register__input-wrap" style="display: flex; gap: 10px; align-items: flex-end; height: auto; margin-bottom: 2rem;">
								<div style="flex: 1; position: relative; height: 37px;">
									<input type="text" id="captcha" name="captcha" class="register__input-field" autocomplete="off">
									<label>Mã xác nhận<span class="red-start">*</span></label>
									<div class="register__error"></div>
								</div>
								<div class="captcha-container" style="height: 37px; display: flex; align-items: center; gap: 5px;">
									<img src="/auth/captcha" id="captcha-img" alt="Captcha" style="height: 100%; border-radius: 4px; cursor: pointer;" title="Click để đổi mã">
									<button type="button" id="refresh-captcha" style="background: none; border: none; cursor: pointer; color: var(--primary-color-1); display: flex; align-items: center;">
										<span class="material-symbols-outlined" style="font-size: 20px;">refresh</span>
									</button>
								</div>
							</div>

							<div class="register__input-wrap">
								<input type="password" id="password" name="password" class="register__input-field" autocomplete="off">
								<label>Mật khẩu<span class="red-start">*</span></label>
								<span id="togglePassword" class="register__toggle-password"><span class="material-symbols-outlined eye-open">visibility</span>
								</span>
								<div class="register__error"></div>
							</div>

							<div class="register__input-wrap">
								<input type="password" id="passwordRepeat" name="passwordRepeat" class="register__input-field" autocomplete="off">
								<label>Nhập lại mật khẩu<span class="red-start">*</span></label>
								<span id="togglePasswordN" class="register__toggle-password"><span class="material-symbols-outlined eye-open">visibility</span>
								</span>
								<div class="register__error"></div>
							</div>
							<!-- <button type="submit">Đăng ký</button> -->
							<input type="submit" value="Đăng ký" class="register__sign-btn">

							<p class="register__text">
								Bằng việc đăng ký, người dùng đồng ý với
								<a href="#">Điều khoản sử dụng</a> và
								<a href="/privacy-policy">Chính sách bảo mật</a>
							</p>
						</div>
					</form>
				</div>

				<div class="register__carousel">
					<div class="register__images-wrapper">
						<img src="/imgs/slider/image1.png" class="register__image register__img-1 show" alt="image1">
						<img src="/imgs/slider/image2.png" class="register__image register__img-2" alt="image2">
						<img src="/imgs/slider/image3.png" class="register__image register__img-3" alt="image3">
					</div>
				</div>
			</div>
		</div>
	</main>

	<%- include('../../components/scrollup') %>
	<%- include('../../partials/footer') %>
	<%- include('../../partials/app-bar') %>

	<!-- Javascript file -->
	<script src="/scripts/pages/auth/register.js"></script>

</body>

</html>