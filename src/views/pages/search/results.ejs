<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="theme-color" content="#2a7ee4" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content="IE104.O12_Nhom2" />
    <meta name="description" content="Tất cả sản phẩm được bày bán ở TECHMO luôn được đảm bảo về nguồn gốc và chất lượng." />

    <link rel="shortcut icon" type="image/x-icon" href="/imgs/ico-logo-blue.png" />
    <link rel="stylesheet" href="/styles/pages/search/results.css" />

    <title>TECHMO. Kết quả tìm kiếm</title>
  </head>

  <body>
    <%- include('../../partials/header', { header: header, user: user }) %>

    <main class="seacrh-result__container">
      <section class="seacrh-result__filter">
        <div class="seacrh-result__filter-normal">
          <h5 class="seacrh-result__filter-normal__title">Bộ lọc:</h5>
          <div class="seacrh-result__filter-normal__content">
            <p>Giá</p>
            <span class="material-symbols-outlined dropdown-button">expand_more</span>
            <form action="/search/results" method="GET" class="dropdown-content">
              <!-- giữ search -->
              <input type="hidden" name="searchKey" value="<%= productListResults.searchKey %>" />

              <div class="filter-list">
                <% 
                  const currentMin = productListResults.minPrice;
                  const currentMax = productListResults.maxPrice;
                  const currentRange = currentMin !== undefined ? (currentMin + '-' + (currentMax || '999999999')) : '';
                %>
                <!-- Dưới 50k -->
                <div class="dropdown-options">
                  <input class="filter-option" type="radio" name="priceRange" id="price-0-50" value="0-50000" <%= currentRange === '0-50000' ? 'checked' : '' %> />
                  <label class="filter-label <%= currentRange === '0-50000' ? 'active' : '' %>" for="price-0-50">Dưới 50k</label>
                </div>

                <!-- 50 - 100 -->
                <div class="dropdown-options">
                  <input class="filter-option" type="radio" name="priceRange" id="price-50-100" value="50000-100000" <%= currentRange === '50000-100000' ? 'checked' : '' %> />
                  <label class="filter-label <%= currentRange === '50000-100000' ? 'active' : '' %>" for="price-50-100">Từ 50k - 100k</label>
                </div>

                <!-- 100 - 150 -->
                <div class="dropdown-options">
                  <input class="filter-option" type="radio" name="priceRange" id="price-100-150" value="100000-150000" <%= currentRange === '100000-150000' ? 'checked' : '' %> />
                  <label class="filter-label <%= currentRange === '100000-150000' ? 'active' : '' %>" for="price-100-150">Từ 100k - 150k</label>
                </div>

                <!-- 150 - 200 -->
                <div class="dropdown-options">
                  <input class="filter-option" type="radio" name="priceRange" id="price-150-200" value="150000-200000" <%= currentRange === '150000-200000' ? 'checked' : '' %> />
                  <label class="filter-label <%= currentRange === '150000-200000' ? 'active' : '' %>" for="price-150-200">Từ 150k - 200k</label>
                </div>

                <!-- >200 -->
                <div class="dropdown-options">
                  <input class="filter-option" type="radio" name="priceRange" id="price-200-plus" value="200000-999999999" <%= currentRange === '200000-999999999' ? 'checked' : '' %> />
                  <label class="filter-label <%= currentRange === '200000-999999999' ? 'active' : '' %>" for="price-200-plus">Trên 200k</label>
                </div>
              </div>

              <div class="filter-dropdown__button">
                <!-- ❗ reset đúng -->
                <div class="filter-dropdown__button">
                  <% 
                    let cancelUrl = '/search/results';
                    if (productListResults.category_id) {
                      cancelUrl += '?category_id=' + productListResults.category_id;
                    } else if (productListResults.searchKey) {
                      cancelUrl += '?searchKey=' + productListResults.searchKey;
                    }
                  %>
                  <button type="button" class="btn btn--outlined pri" onclick="window.location.href='<%= cancelUrl %>'">Hủy bộ lọc</button>

                  <button class="btn btn--filled pri" type="submit">Xem sản phẩm</button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </section>
      <section class="seacrh-result__main">
        <div class="seacrh-result__main__heading">
          <% if (productListResults.searchKey ?? productListResults.category_name) { %>
          <p class="seacrh-result__main__count">
            Tìm thấy
            <span class="seacrh-result__highlight"><%= productListResults.totalRow %></span> kết quả cho từ khóa "
            <span class="seacrh-result__key"><%= productListResults.searchKey ?? productListResults.category_name %></span>"
          </p>
          <% } else { %>
          <p class="seacrh-result__main__count">
            Tìm thấy
            <span class="seacrh-result__highlight"><%= productListResults.totalRow %></span>
            kết quả
          </p>
          <% } %>
          <div class="seacrh-result__form-check">
            <input type="checkbox" class="form-check-input" value="something" id="form-check-input__discount" <%= productListResults.discount ? 'checked' : '' %> />
            <label class="form-check-label" for="form-check-input__discount">Giảm giá</label>
          </div>
          <div class="seacrh-result__sort">
            <p class="seacrh-result__sort-title">Sắp xếp theo:</p>
            <div class="seacrh-result__sort-content">
              <p>Nổi bật</p>
              <span class="material-symbols-outlined">expand_more</span>
            </div>
            <div class="dropdown-content--sort">
              <div class="dropdown-options">
                <input class="sort-option" type="radio" name="sort" id="sort-desc" value="price_desc" />
                <label class="sort-label" for="sort-desc"> Giá cao đến thấp </label>
              </div>

              <hr />

              <div class="dropdown-options">
                <input class="sort-option" type="radio" name="sort" id="sort-asc" value="price_asc" />
                <label class="sort-label" for="sort-asc"> Giá thấp đến cao </label>
              </div>
            </div>
          </div>
        </div>

        <% if (productListResults.totalRow) { %>
        <div class="seacrh-result__main-card">
          <% productListResults.products.slice().forEach(product => { %> <%- include('../../components/product-card', {product: product, toCurrency: formatFunction.toCurrency}) %> <% }) %> <%-
          include('../../components/pagination', {pagination: productListResults}) %>
        </div>
        <% } else { %>
        <div class="search-results--empty">
          <img src="/imgs/search-result--empty.png" alt="empty" />
        </div>
        <% } %>
      </section>
    </main>

    <%- include('../../components/scrollup') %> <%- include('../../partials/footer') %> <%- include('../../partials/app-bar') %>

    <script src="/scripts/pages/search/results.js"></script>
    <script src="/scripts/components/scrollup.js"></script>
    <script src="/scripts/partials/header.js"></script>
    <script>
      document.addEventListener("DOMContentLoaded", () => {
        const form = document.querySelector(".dropdown-content");

        form.addEventListener("submit", (e) => {
          e.preventDefault();

          const selected = document.querySelector('input[name="priceRange"]:checked');
          
          // Lấy URL hiện tại và các params hiện tại
          const url = new URL(window.location.href);
          
          // Xóa các params cũ về giá để cập nhật mới
          url.searchParams.delete("minPrice");
          url.searchParams.delete("maxPrice");
          url.searchParams.delete("page"); // Reset về trang 1 khi lọc

          if (selected) {
            const [min, max] = selected.value.split("-");

            if (min) url.searchParams.set("minPrice", min);
            if (max && max !== "999999999") url.searchParams.set("maxPrice", max);
          }

          window.location.href = url.toString();
        });
      });
    </script>
  </body>
</html>
