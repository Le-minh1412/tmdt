<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <link rel="shortcut icon" href="/imgs/ico-logo-blue.png" />
  <title>TECHMO.Admin - Sửa đơn hàng</title>

  <link rel="stylesheet" href="/styles/admin/pages/cate_view_admin.css" />
  <link rel="stylesheet" href="/styles/admin/pages/product_view_admin.css" />

  <style>
    .row {
      display: flex;
      flex-wrap: wrap;
      gap: 30px;
    }

    .col-md-6 {
      width: calc(50% - 15px);
    }
  </style>
</head>

<body>

<div class="grid-container">
  <%- include('../partials/sidebar_admin') %>
  <%- include('../partials/header_admin', { title: "SỬA ĐƠN HÀNG" }) %>

  <main class="main-container">
    <div class="content container-fluid">

      <div class="page-header">
        <h1>Sửa đơn hàng #<%= order.order_id %></h1>
      </div>

      <form action="/admin/orders_admin/edit/<%= order.order_id %>" method="POST">

        <div class="card">
          <div class="card-body">

            <div class="row">

              <!-- LEFT -->
              <div class="col-md-6">

                <!-- Mã đơn (không sửa) -->
                <div>
                  <label>Mã đơn</label>
                  <input class="form-control" value="<%= order.order_id %>" disabled />
                </div>

                <!-- Tên -->
                <div style="margin-top:15px">
                  <label>Tên người nhận</label>
                  <input 
                    class="form-control"
                    name="order_name"
                    value="<%= order.order_name %>"
                    pattern="^[A-Za-zÀ-ỹ\s]+$"
                    title="Không chứa ký tự đặc biệt"
                    required
                  />
                </div>

                <!-- SĐT -->
                <div style="margin-top:15px">
                  <label>Số điện thoại</label>
                  <input 
                    class="form-control"
                    name="order_phone"
                    value="<%= order.order_phone %>"
                    pattern="[0-9]{10}"
                    maxlength="10"
                    required
                    title="Phải đúng 10 số"
                  />
                </div>

                <!-- Địa chỉ -->
                <div style="margin-top:15px">
                  <label>Địa chỉ</label>
                  <input 
                    class="form-control"
                    name="order_delivery_address"
                    value="<%= order.order_delivery_address %>"
                    required
                  />
                </div>

                <!-- Payment method -->
                <div style="margin-top:15px">
                  <label>Phương thức thanh toán</label>
                  <select class="form-control" name="paying_method_id" required>
                    <% paymentMethods.forEach(function(pm){ %>
                      <option value="<%= pm.paying_method_id %>"
                        <%= pm.paying_method_id == order.paying_method_id ? 'selected' : '' %>>
                        <%= pm.paying_method_name %>
                      </option>
                    <% }) %>
                  </select>
                </div>

                <!-- Status -->
                <div style="margin-top:15px">
                  <label>Trạng thái đơn hàng</label>
                  <select class="form-control" name="order_status" required>
                    <option value="Chờ thanh toán" <%= order.order_status === 'Chờ thanh toán' ? 'selected' : '' %>>Chờ thanh toán</option>
                    <option value="Đang giao hàng" <%= order.order_status === 'Đang giao hàng' ? 'selected' : '' %>>Đang giao hàng</option>
                    <option value="Hoàn thành" <%= order.order_status === 'Hoàn thành' ? 'selected' : '' %>>Hoàn thành</option>
                    <option value="Đã hủy" <%= order.order_status === 'Đã hủy' ? 'selected' : '' %>>Đã hủy</option>
                  </select>
                </div>

              </div>

              <!-- RIGHT -->
              <div class="col-md-6">

                <label style="margin-bottom:10px; display:block">
                  Chi tiết sản phẩm
                </label>

                <% items.forEach(function(item){ %>

                <div style="display:flex; gap:10px; margin-bottom:15px; border-bottom:1px solid #eee; padding-bottom:10px">

                  <img
                    src="/imgs/product_image/P<%= item.product_id %>/<%= item.product_avt_img || 'default.png' %>"
                    style="width:70px;height:70px;object-fit:cover;border-radius:8px"
                    onerror="this.src='/imgs/no-image.png'"
                  />

                  <div>
                    <b><%= item.product_name %></b>
                    <div><%= item.product_variant_name %></div>
                    <div>Số lượng: <%= item.order_detail_quantity %></div>
                    <div>Giá: <%= item.order_detail_price_after %></div>
                  </div>

                </div>

                <% }) %>

              </div>

            </div>

          </div>
        </div>

        <!-- BUTTON -->
        <div style="margin-top:20px; display:flex; gap:10px">

          <a href="/admin/orders_admin"
             style="background:#fff;color:#000;padding:8px 16px;border-radius:6px;text-decoration:none;border:1px solid #ccc;">
            Quay lại
          </a>

          <button type="submit"
            style="background:#2a7ee4;color:#fff;padding:8px 16px;border-radius:6px;border:none;">
            Lưu
          </button>

        </div>

      </form>

    </div>
  </main>
</div>

</body>
</html>