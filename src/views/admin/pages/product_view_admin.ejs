<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="theme-color" content="#2a7ee4" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <meta name="author" content="IE104.O12_Nhom2" />
    <meta name="description" content="TECHMO Admin - Thêm sản phẩm" />

    <link rel="shortcut icon" href="/imgs/ico-logo-blue.png" />
    <link rel="stylesheet" href="/styles/admin/pages/cate_view_admin.css" />
    <link rel="stylesheet" href="/styles/admin/pages/product_view_admin.css" />

    <title>TECHMO.Admin - Thêm sản phẩm</title>
  </head>

  <body>
    <div class="grid-container">
      <!-- SIDEBAR -->
      <%- include('../partials/sidebar_admin') %>

      <!-- HEADER -->
      <%- include('../partials/header_admin', { title: title }) %>

      <!-- MAIN -->
      <main class="main-container">
        <div class="content container-fluid">
          <!-- PAGE HEADER -->
          <div class="page-header">
            <div class="row align-items-center">
              <div class="col-sm">
                <% let breadcrumbData = [ { text: 'Sản phẩm', link:
                '/admin/products_admin' }, { text: 'Thêm sản phẩm', link: '#' }
                ]; %> <%- include('../partials/breadcrumb', { breadcrumb:
                breadcrumbData }) %>

                <div class="page-header__title">
                  <h1>Thêm sản phẩm</h1>
                </div>
              </div>
            </div>
          </div>

          <!-- FORM -->
          <div class="row">
            <form
              action="/admin/products_admin/add"
              method="POST"
              enctype="multipart/form-data"
              style="width: 100%"
            >
              <div class="main-form">
                <!-- THÔNG TIN -->
                <div class="card">
                  <div class="card-header">
                    <h4>Thông tin sản phẩm</h4>
                  </div>

                  <div class="card-body">
                    <!-- NAME -->
                    <div>
                      <label>Tên sản phẩm</label>
                      <input
                        type="text"
                        class="form-control"
                        name="productName"
                        required
                      />
                    </div>

                    <!-- CATEGORY -->
                    <div style="margin-top: 15px">
                      <label>Danh mục</label>

                      <select class="form-control" name="category_id">
                        <% let cats = Array.isArray(categories) ? categories :
                        []; %> <% cats.forEach(function(category) { %>
                        <option value="<%= category.category_id %>">
                          <%= category.category_name %>
                        </option>
                        <% }) %>
                      </select>
                    </div>

                    <!-- DESCRIPTION -->
                    <div style="margin-top: 15px">
                      <label>Mô tả sản phẩm</label>
                      <textarea
                        class="form-control"
                        name="description"
                        rows="5"
                      ></textarea>
                    </div>
                  </div>
                </div>

                <!-- IMAGE -->
                <div class="card" style="margin-top: 20px">
                  <div class="card-header">
                    <h4>Ảnh sản phẩm</h4>
                  </div>

                  <div class="card-body">
                    <input
                      type="file"
                      name="image"
                      id="imageUpload"
                      accept="image/*"
                    />

                    <label for="imageUpload" class="image-upload-label">
                      <span class="material-symbols-rounded">upload</span>
                      Thêm hình ảnh
                    </label>
                  </div>
                </div>

                <!-- SAVE BUTTON (PHẢI TRONG FORM) -->
                <div style="margin-top: 20px">
                  <button type="submit" class="btn-admin btn-primary">
                    <span class="material-symbols-rounded">save</span>
                    Lưu
                  </button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </main>
    </div>

    <script src="/scripts/admin/cate_view_admin.js"></script>
    <script src="/scripts/admin/index_admin.js"></script>
  </body>
</html>
