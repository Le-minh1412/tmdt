<!DOCTYPE html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>TECHMO.Admin - Sửa khuyến mãi</title>

    <link rel="stylesheet" href="/styles/admin/pages/cate_view_admin.css" />
    <link rel="stylesheet" href="/styles/admin/pages/product_view_admin.css" />

    <style>
      .row {
        display: flex;
        flex-wrap: wrap;
        gap: 30px;
      }

      .col-md-6 {
        width: calc(50% - 15px);
      }
    </style>
  </head>

  <body>
    <div class="grid-container">
      <%- include('../partials/sidebar_admin') %> <%- include('../partials/header_admin', { title: "SỬA KHUYẾN MÃI" }) %>

      <main class="main-container">
        <div class="content container-fluid">
          <div class="page-header">
            <h1>Sửa khuyến mãi</h1>
          </div>

          <form action="/admin/discounts_admin/edit/<%= item.discount_id %>" method="POST">
            <div class="card">
              <div class="card-header">
                <h4>Thông tin khuyến mãi</h4>
              </div>

              <div class="card-body">
                <div class="row">
                  <!-- LEFT -->
                  <div class="col-md-6">
                    <div>
                      <label>Tên sự kiện</label>
                      <input type="text" name="discount_name" class="form-control" value="<%= item.discount_name %>" required />
                    </div>

                    <div style="margin-top: 15px">
                      <label>Mô tả</label>
                      <textarea name="discount_description" class="form-control" rows="4"><%= item.discount_description %></textarea>
                    </div>

                    <div style="margin-top: 15px">
                      <label>Ngày bắt đầu</label>
                      <input type="date" name="discount_start_date" class="form-control" value="<%= item.discount_start_date.toISOString().split('T')[0] %>" required />
                    </div>

                    <div style="margin-top: 15px">
                      <label>Ngày kết thúc</label>
                      <input type="date" name="discount_end_date" class="form-control" value="<%= item.discount_end_date.toISOString().split('T')[0] %>" required />
                    </div>

                    <div style="margin-top: 15px">
                      <label>Giảm giá (%)</label>
                      <input type="number" step="1" name="discount_amount" class="form-control" value="<%= item.discount_amount %>" min="0" max="100" required />
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- SAVE -->
            <div style="margin-top: 20px">
              <button type="submit" class="btn-admin btn-primary">Cập nhật</button>
            </div>
          </form>
        </div>
      </main>
    </div>
  </body>
</html>
